#include <stdio.h>
#include <string.h>
#include <stdlib.h>

#define رئيسي main
#define نجاح 0
#define اكتب printf
#define اقرأ scanf

/* بنك الأخطاء والحلول */
typedef struct {
    محرف *إنجليزي;
    محرف *عربي;
    محرف *حل;
} خطأ_مترجم;

خطأ_مترجم قاموس[] = {
    {"error: expected ';'", "ناقص فاصلة منقوطة ;", "أضف ; في نهاية السطر السابق"},
    {"error: expected '}'", "ناقص قوس إغلاق }", "تأكد من إغلاق كل الأقواس"},
    {"error: expected '('", "ناقص قوس فتح (", "تأكد من وجود ( بعد اسم الدالة"},
    {"error: undeclared", "متغير غير معرف", "عرف المتغير قبل استخدامه: عدد اسم_المتغير;"},
    {"error: too few arguments", "عدد المعاملات غير كاف", "تأكد من تمرير كل المعاملات المطلوبة"},
    {"error: too many arguments", "عدد المعاملات زائد", "احذف المعاملات الزائدة"},
    {"error: unknown type name", "نوع غير معروف", "تأكد من تعريف النوع أو استخدم عدد/محرف/عدم"},
    {"macro.*requires.*arguments", "خطأ في ماكرو", "تأكد من عدد المعاملات في الماكرو"},
    {"implicit declaration", "دالة غير معرفة", "أضف تعريف الدالة قبل استخدامها"},
    {"undefined reference", "مرجع غير معرف", "تأكد من وجود الدالة أو اربط المكتبة المطلوبة"},
    {"No such file", "ملف غير موجود", "تأكد من اسم الملف ومساره"},
    {"NULL", "فارغ", "لا يوجد خطأ معروف"},
    {"error:", "خطأ:", "راجع السطر المذكور"},
    {"warning:", "تحذير:", "يمكن تجاهله لكن يفضل إصلاحه"},
};

#define عدد_الأخطاء (sizeof(قاموس)/sizeof(قاموس[0]))

/* دالة ترجمة الخطأ */
عدم ترجم_خطأ(محرف *سطر) {
    اكتب("📝 %s", سطر);
    
    لكل (عدد ع = 0; ع < عدد_الأخطاء; ع = ع + 1) {
        اذا (strstr(سطر, قاموس[ع].إنجليزي)) {
            اكتب("   ↳ 🔴 %s\n", قاموس[ع].عربي);
            اكتب("   ↳ 🟢 الحل: %s\n", قاموس[ع].حل);
            ارجع;
        }
    }
}

/* دالة تحليل وتلخيص */
عدم لخص_الأخطاء(عدد أخطاء, عدد تحذيرات) {
    اكتب("\n╔══════════════════════════════╗\n");
    اكتب("║  📊 ملخص الترجمة             ║\n");
    اكتب("╠══════════════════════════════╣\n");
    اكتب("║  ❌ أخطاء:   %d               ║\n", أخطاء);
    اكتب("║  ⚠️  تحذيرات: %d               ║\n", تحذيرات);
    
    اذا (أخطاء == 0) {
        اكتب("║  ✅ تمت الترجمة بنجاح!        ║\n");
    } والا {
        اكتب("║  💡 جرب: حداد2 --مساعدة      ║\n");
    }
    اكتب("╚══════════════════════════════╝\n\n");
}

