#ادرج "بصمة.ع"
#ادرج "كرتونة.ع"
#ادرج "خط.ع"
#ادرج "نظام.ع"
#ادرج "نصوص.ع"
#ادرج "ملفات.ع"

#عرف عرض_شاشة 1000
#عرف ارتفاع_شاشة 700

محرف نصوص[500][1024];
عدد اس = 1, سط = 0, عم = 0;
محرف اسم[256] = "مشروع_1.سيف";
محرف *مش[50];
عدد مشع = 0;

نافذة *نو;
راسم *رس;
خط *خ;

/* دالة رسم نص عربي */
عدم رسم_نص(محرف *ت, عدد س, عدد ص, عدد ح, عدد خ, عدد ز) {
    لون ل = {ح, خ, ز, 255};
    سطح *سطح_نص = ارسم_نص_عربي(خ, ت, ل);
    اذا (!سطح_نص) ارجع;
    نسيج *نس = حول_سطح_الى_نسيج(رس, سطح_نص);
    مستطيل مكان = {س, ص, سطح_نص->w, سطح_نص->h};
    انسخ_النسيج(رس, نس, فارغ, &مكان);
    حرر_سطح(سطح_نص);
    حرر_نسيج(نس);
}

عدم زر(محرف *ت, عدد س, عدد ص, عدد ع, عدد ط) {
    استعمل_لون(رس, 50, 50, 80);
    مستطيل م = {س, ص, ع, ط};
    املأ_مستطيل(رس, &م);
    رسم_نص(ت, س+8, ص+5, 200, 200, 255);
}

عدد هل_كلمة(محرف *ك) {
    محرف *كل[] = {"عدد","محرف","اذا","والا","والا_اذا","طالما","لكل","تفرع","حالة","افتراضي","توقف","استمر","ارجع","رئيسي","هيكل","تعريف_نوع", فارغ};
    لكل (عدد ع = 0; كل[ع]; ع++)
        اذا (قارن_نص(ك, كل[ع]) == 0) ارجع 1;
    ارجع 0;
}

عدم حمل_مشاريع() {
    مجلد *د = افتتح_مجلد(".");
    مدخل_مجلد *م;
    مشع = 0;
    طالما ((م = اقرأ_مجلد(د)) && مشع < 50)
        اذا (بحث_نص(م->d_name, ".سيف"))
            مش[مشع++] = نسخ_نص(م->d_name);
    اغلق_مجلد(د);
}

عدم حفظ(محرف *م) {
    ملف *ف = افتتح(م, "w");
    اذا (!ف) ارجع;
    لكل (عدد ع = 0; ع < اس; ع++)
        اكتب_في(ف, "%s\n", نصوص[ع]);
    اغلق(ف);
}

عدم افتح(محرف *م) {
    ملف *ف = افتتح(م, "r");
    اذا (!ف) { اس = 1; نصوص[0][0] = '\0'; ارجع; }
    اس = 0;
    طالما (اقرأ_سطر(نصوص[اس], 1024, ف) && اس < 500) {
        عدد ط = طول_نص(نصوص[اس]);
        اذا (ط > 0 && نصوص[اس][ط-1] == '\n') نصوص[اس][ط-1] = '\0';
        اس++;
    }
    اغلق(ف);
    سط = 0;
    عم = 0;
}

عدد رئيسي() {
    ابدأ_الخط();
    ابدأ_الرسوم();
    خ = افتتح_خط("/usr/share/fonts/truetype/scheherazade/Scheherazade-Regular.ttf", 16);
    نو = افتتح_نافذة("📝 ورّاق العربي", عرض_شاشة, ارتفاع_شاشة);
    رس = افتتح_راسم(نو);
    حمل_مشاريع();
    
    عدد تشغيل = صحيح, قا = 0;
    ابدأ_ادخال_نص();
    
    طالما (تشغيل) {
        طالما (هل_حدث()) {
            اذا (هل_خروج()) تشغيل = خطأ;
            اذا (نوع_الحدث == حدث_نص) {
                اذا (عم < 1023) { نصوص[سط][عم++] = نص_مدخل; نصوص[سط][عم] = '\0'; }
            }
            اذا (نوع_الحدث == حدث_مفاتيح) {
                تفرع (حدث_عام.key.keysym.sym) {
                    حالة مفتاح_دخول: اس++; سط++; عم = 0; توقف;
                    حالة مفتاح_حذف: اذا (عم > 0) نصوص[سط][--عم] = '\0'; توقف;
                    حالة مفتاح_أعلى: اذا (سط > 0) سط--; توقف;
                    حالة مفتاح_أسفل: اذا (سط < اس-1) سط++; توقف;
                    حالة مفتاح_يسار: اذا (عم > 0) عم--; توقف;
                    حالة مفتاح_يمين: اذا (نصوص[سط][عم]) عم++; توقف;
                    حالة مفتاح_ف1: قا = !قا; توقف;
                    حالة مفتاح_ف2: حفظ(اسم); توقف;
                }
            }
            اذا (نوع_الحدث == حدث_فأرة) {
                عدد سف = موقع_الفأرة_س, صف = موقع_الفأرة_ص;
                اذا (قا)
                    لكل (عدد ع = 0; ع < مشع; ع++)
                        اذا (صف > 100+ع*30 && صف < 130+ع*30) {
                            افتح(مش[ع]);
                            انسخ_نص(اسم, مش[ع]);
                            قا = 0;
                        }
                اذا (سف > 10 && سف < 110 && صف > 5 && صف < 35) حفظ(اسم);
                اذا (سف > 120 && سف < 220 && صف > 5 && صف < 35) {
                    محرف م[512];
                    اكتب_منسق(م, "مشروع_%d.سيف", مشع+1);
                    حفظ(م);
                    حمل_مشاريع();
                }
                اذا (سف > 230 && سف < 330 && صف > 5 && صف < 35) قا = !قا;
            }
        }
        
        استعمل_لون(رس, 30, 30, 30);
        امسح_اللوحة(رس);
        استعمل_لون(رس, 20, 20, 20);
        مستطيل ش = {0, 0, عرض_شاشة, 45};
        املأ_مستطيل(رس, &ش);
        زر("💾 F2", 10, 5, 100, 30);
        زر("📁 F3", 120, 5, 100, 30);
        زر("📂 F1", 230, 5, 100, 30);
        رسم_نص(اسم, 350, 10, 200, 200, 200);
        
        لكل (عدد ص = 0; ص < اس && ص < 28; ص++) {
            محرف رق[8];
            اكتب_منسق(رق, "%3d", ص+1);
            رسم_نص(رق, 10, 60+ص*22, 100, 100, 100);
            محرف *ك = جزئ_نص(نصوص[ص], " \t");
            عدد س2 = 55;
            طالما (ك) {
                اذا (ك[0] == '/' && ك[1] == '/') { رسم_نص(ك, س2, 60+ص*22, 100, 100, 100); توقف; }
                اذا (ك[0] == '"') رسم_نص(ك, س2, 60+ص*22, 150, 255, 150);
                والا اذا (هل_كلمة(ك)) رسم_نص(ك, س2, 60+ص*22, 100, 180, 255);
                والا رسم_نص(ك, س2, 60+ص*22, 200, 200, 200);
                س2 += طول_نص(ك) * 10 + 10;
                ك = جزئ_نص(فارغ, " \t");
            }
        }
        
        اذا (قا) {
            استعمل_لون(رس, 40, 40, 60);
            مستطيل ق = {300, 80, 400, 500};
            املأ_مستطيل(رس, &ق);
            لكل (عدد ع = 0; ع < مشع; ع++)
                رسم_نص(مش[ع], 320, 120+ع*30, 200, 200, 255);
        }
        
        استعمل_لون(رس, 255, 255, 0);
        مستطيل مؤشر = {55 + عم*10, 60 + سط*22, 2, 18};
        املأ_مستطيل(رس, &مؤشر);
        
        اظهر_اللوحة(رس);
        انتظر(16);
    }
    
    اوقف_ادخال_نص();
    اغلق_خط(خ);
    اغلق_راسم(رس);
    اغلق_نافذة(نو);
    اختم_الرسوم();
    ارجع نجاح;
}
