#ادرج "بصمة.ع"
#ادرج "كرتونة.ع"
#ادرج "نظام.ع"

#عرف حجم_خلية 20
#عرف عرض_شبكة 30
#عرف ارتفاع_شبكة 20

عدد جسم[100][2];
عدد طول = 3;
عدد اتجاه_س = 1, اتجاه_ص = 0;
عدد طعام_س, طعام_ص;
عدد تشغيل = صحيح;
عدد نقاط = 0;

عدم ضع_طعام() {
    طعام_س = (عشوائي() % عرض_شبكة) * حجم_خلية;
    طعام_ص = (عشوائي() % ارتفاع_شبكة) * حجم_خلية;
}

عدد رئيسي() {
    ابدأ_الرسوم();
    نافذة *نو = افتتح_نافذة("🐍 ثعبان سيف", 600, 400);
    راسم *رس = افتتح_راسم(نو);
    
    بذرة_عشوائية(وقت(0));
    جسم[0][0] = 5; جسم[0][1] = 5;
    ضع_طعام();
    
    عدد اطار = 0;
    
    طالما (تشغيل) {
        طالما (هل_حدث()) {
            اذا (هل_خروج()) تشغيل = خطأ;
            اذا (نوع_الحدث == حدث_مفاتيح) {
                تفرع (حدث_عام.key.keysym.sym) {
                    حالة مفتاح_أعلى: اذا (اتجاه_ص != 1) { اتجاه_س = 0; اتجاه_ص = -1; } توقف;
                    حالة مفتاح_أسفل: اذا (اتجاه_ص != -1) { اتجاه_س = 0; اتجاه_ص = 1; } توقف;
                    حالة مفتاح_يسار: اذا (اتجاه_س != 1) { اتجاه_س = -1; اتجاه_ص = 0; } توقف;
                    حالة مفتاح_يمين: اذا (اتجاه_س != -1) { اتجاه_س = 1; اتجاه_ص = 0; } توقف;
                }
            }
        }
        
        اطار = اطار + 1;
        اذا (اطار % 10 != 0) { انتظر(10); استمر; }
        
        /* تحريك الجسم */
        لكل (عدد ع = طول; ع > 0; ع = ع - 1) {
            جسم[ع][0] = جسم[ع-1][0];
            جسم[ع][1] = جسم[ع-1][1];
        }
        جسم[0][0] = جسم[0][0] + اتجاه_س;
        جسم[0][1] = جسم[0][1] + اتجاه_ص;
        
        /* أكل الطعام */
        اذا (جسم[0][0] == طعام_س / حجم_خلية && جسم[0][1] == طعام_ص / حجم_خلية) {
            طول = طول + 1;
            نقاط = نقاط + 10;
            ضع_طعام();
        }
        
        /* تصادم مع الجدران */
        اذا (جسم[0][0] < 0 || جسم[0][0] >= عرض_شبكة || جسم[0][1] < 0 || جسم[0][1] >= ارتفاع_شبكة)
            تشغيل = خطأ;
        
        /* رسم الخلفية */
        استعمل_لون(رس, 0, 0, 0);
        امسح_اللوحة(رس);
        
        /* رسم الطعام */
        استعمل_لون(رس, 255, 0, 0);
        مستطيل ط = {طعام_س, طعام_ص, حجم_خلية - 2, حجم_خلية - 2};
        املأ_مستطيل(رس, &ط);
        
        /* رسم الجسم */
        استعمل_لون(رس, 0, 255, 0);
        لكل (عدد ع = 0; ع < طول; ع = ع + 1) {
            مستطيل خ = {جسم[ع][0]*حجم_خلية + 1, جسم[ع][1]*حجم_خلية + 1, حجم_خلية - 3, حجم_خلية - 3};
            املأ_مستطيل(رس, &خ);
        }
        
        اظهر_اللوحة(رس);
        انتظر(10);
    }
    
    اكتب("🎉 انتهت اللعبة! النقاط: %d\n", نقاط);
    
    اغلق_راسم(رس);
    اغلق_نافذة(نو);
    اختم_الرسوم();
    ارجع نجاح;
}
