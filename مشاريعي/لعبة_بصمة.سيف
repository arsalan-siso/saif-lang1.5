#ادرج "بصمة.ع"
#ادرج "كرتونة.ع"

عدد رئيسي() {
    ابدأ_الرسوم();
    نافذة *نو = افتتح_نافذة("⚔️ بصمة", 800, 600);
    راسم *رس = افتتح_راسم(نو);
    
    عدد س = 400, ص = 300, سرعة_س = 4, سرعة_ص = 3;
    عدد تشغيل = صحيح;
    
    طالما (تشغيل) {
        طالما (هل_حدث()) {
            اذا (هل_خروج()) تشغيل = خطأ;
            اذا (اضغط_مفتاح(مفتاح_هروب)) تشغيل = خطأ;
        }
        
        س = س + سرعة_س;
        ص = ص + سرعة_ص;
        
        اذا (س <= 30 || س >= 770) سرعة_س = -سرعة_س;
        اذا (ص <= 30 || ص >= 570) سرعة_ص = -سرعة_ص;
        
        استعمل_لون(رس, 0, 0, 0);
        امسح_اللوحة(رس);
        
        استعمل_لون(رس, 255, 255, 255);
        ارسم_دائرة(رس, س, ص, 30);
        
        استعمل_لون(رس, 0, 0, 255);
        مستطيل إطار_علوي = {0, 0, 800, 5};
        املأ_مستطيل(رس, &إطار_علوي);
        
        استعمل_لون(رس, 255, 0, 0);
        مستطيل إطار_جانبي = {0, 0, 5, 600};
        املأ_مستطيل(رس, &إطار_جانبي);
        
        اظهر_اللوحة(رس);
        انتظر(16);
    }
    
    اغلق_راسم(رس);
    اغلق_نافذة(نو);
    اختم_الرسوم();
    ارجع نجاح;
}
