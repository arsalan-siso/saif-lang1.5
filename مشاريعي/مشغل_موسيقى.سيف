#ادرج "صوت.ع"
#ادرج "كرتونة.ع"

عدد رئيسي() {
    /* إعدادات متقدمة */
    افتح_صوت_مخصص(48000, 2, 4096);  /* جودة عالية */
    
    اكتب_سطر("🎵 مشغل الموسيقى العربي");
    اكتب_سطر("الأوامر: ش=شغل, ق=ايقاف, م=مؤقت, س=استئناف, خ=خروج");
    
    محرف أمر;
    عدد تشغيل = صحيح;
    
    طالما (تشغيل) {
        اكتب("🎵> ");
        اقرأ("%c", &أمر);
        
        تفرع (أمر) {
            حالة 'ش':
                شغل_بتلاشي("اغنية.mp3", -1, 3000);  /* تلاشي دخول 3 ثوان */
                اكتب_سطر("▶️ تشغيل");
                توقف;
            حالة 'ق':
                تلاشى_خارج(2000);  /* تلاشي خروج 2 ثانية */
                اكتب_سطر("⏹️ توقف");
                توقف;
            حالة 'م':
                ايقاف_مؤقت();
                اكتب_سطر("⏸️ مؤقت");
                توقف;
            حالة 'س':
                استئناف();
                اكتب_سطر("▶️ استئناف");
                توقف;
            حالة 'خ':
                تشغيل = خطأ;
                توقف;
        }
    }
    
    اوقف_الكل();
    ارجع نجاح;
}
