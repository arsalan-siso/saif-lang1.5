#ادرج "صوت.ع"
#ادرج "بصمة.ع"
#ادرج "كرتونة.ع"

عدد رئيسي() {
    ابدأ_الصوت();
    ابدأ_الرسوم();
    
    نافذة *نو = افتتح_نافذة("🎵 لعبة بصوت", 800, 600);
    راسم *رس = افتتح_راسم(نو);
    
    /* تحميل المؤثرات */
    عدم *صوت_قفز = حمل_مؤثر("قفز.wav");
    عدم *صوت_ارتطام = حمل_مؤثر("ارتطام.wav");
    
    عدد س = 400, ص = 300, سرعة_س = 4, سرعة_ص = 3;
    عدد تشغيل = صحيح;
    
    طالما (تشغيل) {
        طالما (هل_حدث()) {
            اذا (هل_خروج()) تشغيل = خطأ;
            اذا (اضغط_مفتاح(مفتاح_مسافة)) {
                شغل_مؤثر(صوت_قفز);  /* صوت عند القفز */
            }
        }
        
        س = س + سرعة_س;
        ص = ص + سرعة_ص;
        
        اذا (س <= 30 || س >= 770) {
            سرعة_س = -سرعة_س;
            شغل_مؤثر(صوت_ارتطام);  /* صوت عند الارتطام */
        }
        اذا (ص <= 30 || ص >= 570) {
            سرعة_ص = -سرعة_ص;
            شغل_مؤثر(صوت_ارتطام);
        }
        
        استعمل_لون(رس, 0, 0, 0);
        امسح_اللوحة(رس);
        استعمل_لون(رس, 255, 255, 255);
        ارسم_دائرة(رس, س, ص, 30);
        
        اظهر_اللوحة(رس);
        انتظر(16);
    }
    
    اغلق_راسم(رس);
    اغلق_نافذة(نو);
    اختم_الرسوم();
    اوقف_الكل();
    ارجع نجاح;
}
