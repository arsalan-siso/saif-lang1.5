#ادرج "بصمة.ع"
#ادرج "كرتونة.ع"
#ادرج "خط.ع"

#عرف عرض_شاشة 1000
#عرف ارتفاع_شاشة 700

نافذة *نو;
راسم *رس;

/* دالة رسم نص - بسيطة ومباشرة */
عدم ارسم_نص(محرف *ت, عدد س, عدد ص, عدد ح, عدد خ, عدد ز, عدد كبر) {
    لون ل = {ح, خ, ز, 255};
    خط *خ_مؤقت = افتتح_خط("/usr/share/fonts/truetype/scheherazade/Scheherazade-Regular.ttf", كبر);
    اذا (!خ_مؤقت) ارجع;
    
    سطح *سطح_نص = ارسم_نص_عربي(خ_مؤقت, ت, ل);
    اذا (!سطح_نص) { اغلق_خط(خ_مؤقت); ارجع; }
    
    نسيج *نس = حول_سطح_الى_نسيج(رس, سطح_نص);
    مستطيل مكان = {س, ص, سطح_نص->w, سطح_نص->h};
    انسخ_النسيج(رس, نس, فارغ, &مكان);
    حرر_سطح(سطح_نص);
    حرر_نسيج(نس);
    اغلق_خط(خ_مؤقت);
}

عدد رئيسي() {
    ابدأ_الخط();
    ابدأ_الرسوم();
    نو = افتتح_نافذة("📝 ورّاق", عرض_شاشة, ارتفاع_شاشة);
    رس = افتتح_راسم(نو);
    
    استعمل_لون(رس, 20, 20, 40);
    امسح_اللوحة(رس);
    
    /* اختبار النصوص */
    ارسم_نص("مرحبا", 50, 50, 255, 255, 255, 24);
    ارسم_نص("بالعالم", 50, 80, 255, 255, 0, 20);
    ارسم_نص("ABCDEFG", 50, 130, 0, 255, 0, 18);
    
    اظهر_اللوحة(رس);
    انتظر(5000);
    
    اغلق_راسم(رس);
    اغلق_نافذة(نو);
    اختم_الرسوم();
    ارجع نجاح;
}
