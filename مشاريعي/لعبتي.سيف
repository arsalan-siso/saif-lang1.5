#ادرج "بصمة.ع"
#ادرج "كرتونة.ع"

عدد رئيسي() {
    ابدأ_الرسوم();
    نافذة *نو = افتتح_نافذة("⚔️ لعبتي", 800, 600);
    راسم *رس = افتتح_راسم(نو);
    
    عدد س = 400, ص = 300, سرعة_س = 5, سرعة_ص = 3;
    عدد تشغيل = صحيح;
    
    طالما (تشغيل) {
        طالما (هل_حدث())
            اذا (هل_خروج()) تشغيل = خطأ;
        
        س = س + سرعة_س;
        ص = ص + سرعة_ص;
        
        اذا (س <= 20 || س >= 780) سرعة_س = -سرعة_س;
        اذا (ص <= 20 || ص >= 580) سرعة_ص = -سرعة_ص;
        
        استعمل_لون(رس, 0, 0, 0);
        امسح_اللوحة(رس);
        استعمل_لون(رس, 255, 255, 255);
        
        ارسم_دائرة(رس, س, ص, 20);
        
        اظهر_اللوحة(رس);
        انتظر(16);
    }
    
    اغلق_راسم(رس);
    اغلق_نافذة(نو);
    اختم_الرسوم();
    ارجع نجاح;
}
