    راسم *رس = افتتح_راسم(نو);
    
    استعمل_لون(رس, 0, 0, 255);
    امسح_اللوحة(رس);
    اظهر_اللوحة(رس);
    انتظر(2000);
    
    اغلق_راسم(رس);
    اغلق_نافذة(نو);
