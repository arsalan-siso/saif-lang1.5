#ifndef صوت_مكتبة
#define صوت_مكتبة

#include <SDL2/SDL.h>
#include <SDL2/SDL_mixer.h>

/* ═══════════════════════════════════════════
   المستوى الأول - الأساسيات (3 دوال)
   ═══════════════════════════════════════════ */

/* شغّل الصوت ببساطة */
#define ابدأ_الصوت()       Mix_OpenAudio(44100, MIX_DEFAULT_FORMAT, 2, 2048)
#define شغل_صوت(ملف)       Mix_PlayMusic(Mix_LoadMUS(ملف), -1)
#define اوقف_الصوت()       Mix_HaltMusic()

/* ═══════════════════════════════════════════
   المستوى الثاني - مؤثرات
   ═══════════════════════════════════════════ */

/* تحميل مؤثر صوتي */
عدم* حمل_مؤثر(محرف *ملف) {
    return Mix_LoadWAV(ملف);
}

#define شغل_مؤثر(م)        Mix_PlayChannel(-1, م, 0)
#define اوقف_كل_المؤثرات() Mix_HaltChannel(-1)
#define حجم_الصوت(م)       Mix_VolumeMusic(م)
#define حجم_مؤثر(ق,ح)      Mix_Volume(ق,ح)

/* ═══════════════════════════════════════════
   المستوى الثالث - تحكم كامل
   ═══════════════════════════════════════════ */

/* معلومات الصوت */
تعريف_نوع هيكل {
    عدد تردد;
    عدد قنوات;
    عدد عينات;
} معلومات_صوت;

/* فتح الصوت بإعدادات مخصصة */
عدد افتح_صوت_مخصص(عدد تردد, عدد قنوات, عدد حجم_عينة) {
    return Mix_OpenAudio(تردد, MIX_DEFAULT_FORMAT, قنوات, حجم_عينة);
}

/* تشغيل موسيقى مع خيارات */
#define شغل_موسيقى(ملف, تكرار)     Mix_PlayMusic(Mix_LoadMUS(ملف), تكرار)
#define شغل_بتلاشي(ملف,تكرار,زمن)  Mix_FadeInMusic(Mix_LoadMUS(ملف), تكرار, زمن)

/* التحكم */
#define ايقاف_مؤقت()               Mix_PauseMusic()
#define استئناف()                  Mix_ResumeMusic()
#define اعادة_تشغيل()              Mix_RewindMusic()
#define تلاشى_خارج(زمن)            Mix_FadeOutMusic(زمن)
#define اوقف_الكل()                Mix_CloseAudio()

/* الاستعلام */
#define هل_يعمل()                  Mix_PlayingMusic()
#define هل_متوقف_مؤقتا()           Mix_PausedMusic()

#endif /* صوت_مكتبة */
